import os

class Producto:
    def __init__(self, id_prod, nombre, cantidad, precio):
        self.id_prod = id_prod
        self.nombre = nombre
        self.cantidad = int(cantidad)
        self.precio = float(precio)

    def __str__(self):
        # Formato CSV simple para el archivo: id,nombre,cantidad,precio
        return f"{self.id_prod},{self.nombre},{self.cantidad},{self.precio}"

class Inventario:
    def __init__(self, archivo="inventario.txt"):
        self.archivo = archivo
        self.productos = {}
        # Cargar datos existentes al instanciar la clase
        self.cargar_desde_archivo()

    def cargar_desde_archivo(self):
        """Lee el archivo y reconstruye el diccionario de productos."""
        try:
            if not os.path.exists(self.archivo):
                # Si no existe, lo creamos vacío
                with open(self.archivo, 'w', encoding='utf-8') as f:
                    pass
                print(f"Archivo '{self.archivo}' creado exitosamente.")
                return

            with open(self.archivo, 'r', encoding='utf-8') as f:
                for linea in f:
                    linea = linea.strip()
                    if linea:
                        id_p, nombre, cant, precio = linea.split(',')
                        nuevo_p = Producto(id_p, nombre, cant, precio)
                        self.productos[id_p] = nuevo_p
            print("Datos cargados correctamente desde el archivo.")

        except FileNotFoundError:
            print("Error: No se encontró el archivo de inventario.")
        except PermissionError:
            print("Error: No tienes permisos para acceder al archivo.")
        except ValueError:
            print("Error: El archivo contiene datos corruptos o con formato incorrecto.")
        except Exception as e:
            print(f"Ocurrió un error inesperado al cargar: {e}")

    def guardar_en_archivo(self):
        """Sobrescribe el archivo con la información actual en memoria."""
        try:
            with open(self.archivo, 'w', encoding='utf-8') as f:
                for p in self.productos.values():
                    f.write(str(p) + "\n")
        except PermissionError:
            print("Error: No se pudo escribir en el archivo (permiso denegado).")
        except Exception as e:
            print(f"Error al guardar los datos: {e}")

    def agregar_producto(self, producto):
        if producto.id_prod in self.productos:
            print(f"Error: El ID {producto.id_prod} ya existe.")
        else:
            self.productos[producto.id_prod] = producto
            self.guardar_en_archivo()
            print(f"Producto '{producto.nombre}' agregado y sincronizado en archivo.")

    def actualizar_producto(self, id_prod, nueva_cantidad):
        if id_prod in self.productos:
            self.productos[id_prod].cantidad = nueva_cantidad
            self.guardar_en_archivo()
            print(f"Stock de ID {id_prod} actualizado en archivo.")
        else:
            print("Error: Producto no encontrado para actualizar.")

    def eliminar_producto(self, id_prod):
        if id_prod in self.productos:
            eliminado = self.productos.pop(id_prod)
            self.guardar_en_archivo()
            print(f"Producto '{eliminado.nombre}' eliminado del inventario y del archivo.")
        else:
            print("Error: No se puede eliminar, el ID no existe.")

    def mostrar_inventario(self):
        if not self.productos:
            print("El inventario está vacío.")
        else:
            print("\n--- Inventario Actual ---")
            for p in self.productos.values():
                print(f"ID: {p.id_prod} | Nombre: {p.nombre} | Cantidad: {p.cantidad} | Precio: ${p.precio:.2f}")
            print("-------------------------\n")

# --- Bloque de Prueba del Sistema ---
if __name__ == "__main__":
    # 1. Iniciamos el sistema (esto cargará el archivo si ya existe)
    mi_gestion = Inventario()

    # 2. Agregamos algunos productos de prueba
    p1 = Producto("A1", "Monitor 24'", 5, 150.00)
    p2 = Producto("B2", "Teclado Mecánico", 15, 45.50)
    
    mi_gestion.agregar_producto(p1)
    mi_gestion.agregar_producto(p2)

    # 3. Mostramos lo que hay
    mi_gestion.mostrar_inventario()

    # 4. Probamos actualización
    mi_gestion.actualizar_producto("A1", 8)

    # 5. Volvemos a mostrar para verificar
    mi_gestion.mostrar_inventario()
