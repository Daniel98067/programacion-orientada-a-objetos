import tkinter as tk
from tkinter import messagebox
import os

class TodoApp:
    def __init__(self, root):
        self.root = root
        self.root.title("Gestor de Tareas con Autoguardado")
        self.root.geometry("400x450")
        self.archivo_datos = "tareas.txt" # Archivo donde se guardarán los datos

        # --- Interfaz ---
        self.task_entry = tk.Entry(root, font=("Arial", 12))
        self.task_entry.pack(pady=10, padx=20, fill=tk.X)
        self.task_entry.bind("<Return>", lambda event: self.add_task())

        self.add_button = tk.Button(root, text="Añadir Tarea", command=self.add_task, bg="#4CAF50", fg="white")
        self.add_button.pack(pady=5)

        self.tasks_listbox = tk.Listbox(root, font=("Arial", 11))
        self.tasks_listbox.pack(pady=10, padx=20, fill=tk.BOTH, expand=True)

        button_frame = tk.Frame(root)
        button_frame.pack(pady=10)

        tk.Button(button_frame, text="Marcar Completada", command=self.mark_completed, bg="#2196F3", fg="white").grid(row=0, column=0, padx=5)
        tk.Button(button_frame, text="Eliminar Tarea", command=self.delete_task, bg="#F44336", fg="white").grid(row=0, column=1, padx=5)

        # --- Cargar datos al iniciar ---
        self.load_tasks()

    def save_tasks(self):
        """Guarda todas las tareas del Listbox en el archivo de texto."""
        with open(self.archivo_datos, "w", encoding="utf-8") as f:
            tasks = self.tasks_listbox.get(0, tk.END)
            for task in tasks:
                f.write(task + "\n")

    def load_tasks(self):
        """Lee el archivo de texto y carga las tareas en el Listbox."""
        if os.path.exists(self.archivo_datos):
            with open(self.archivo_datos, "r", encoding="utf-8") as f:
                for line in f:
                    self.tasks_listbox.insert(tk.END, line.strip())

    def add_task(self):
        task = self.task_entry.get()
        if task != "":
            self.tasks_listbox.insert(tk.END, task)
            self.task_entry.delete(0, tk.END)
            self.save_tasks() # Guardar después de añadir
        else:
            messagebox.showwarning("Advertencia", "Escribe una tarea.")

    def mark_completed(self):
        try:
            index = self.tasks_listbox.curselection()[0]
            task = self.tasks_listbox.get(index)
            if "[COMPLETADA]" not in task:
                self.tasks_listbox.delete(index)
                self.tasks_listbox.insert(index, f"{task} [COMPLETADA]")
                self.tasks_listbox.itemconfig(index, fg="gray")
                self.save_tasks() # Guardar cambio de estado
        except IndexError:
            messagebox.showwarning("Selección", "Selecciona una tarea.")

    def delete_task(self):
        try:
            index = self.tasks_listbox.curselection()[0]
            self.tasks_listbox.delete(index)
            self.save_tasks() # Guardar después de eliminar
        except IndexError:
            messagebox.showwarning("Selección", "Selecciona una tarea.")

if __name__ == "__main__":
    root = tk.Tk()
    app = TodoApp(root)
    root.mainloop()
